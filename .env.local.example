# Optional. Without this, the app uses warm built-in narration (fully free).
# With it, stops get rewritten warmer by Groq (free tier).
# Get a key at https://console.groq.com  ->  API Keys
GROQ_API_KEY=your_key_here

# Optional. Without this, the chat widget shows a "not set up" message.
# Powers /api/chat (the in-app assistant). Pay-as-you-go, needs a small prepaid balance.
# Get a key at https://platform.deepseek.com  ->  API Keys
DEEPSEEK_API_KEY=your_key_here
